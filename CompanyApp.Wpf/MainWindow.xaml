<Window x:Class="CompanyApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление компанией"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <TabControl Margin="12">
        <TabItem Header="Сотрудники">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Content="Добавить" Command="{Binding Employees.AddCommand}" />
                    <Button Margin="0,0,8,0" Content="Редактировать" Command="{Binding Employees.EditCommand}" />
                    <Button Margin="0,0,8,0" Content="Просмотр" Command="{Binding Employees.ViewCommand}" />
                    <Button Margin="0,0,8,0" Content="Удалить" Command="{Binding Employees.DeleteCommand}" />
                    <Button Content="Обновить" Command="{Binding Employees.RefreshCommand}" />
                </StackPanel>
                <DataGrid x:Name="EmployeesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Employees.Items}"
                          SelectedItem="{Binding Employees.SelectedItem}"
                          MouseDoubleClick="EmployeesGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*" />
                        <DataGridTextColumn Header="Должность" Binding="{Binding Position, Converter={StaticResource EnumDescriptionConverter}}" Width="150" />
                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="150" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <TabItem Header="Контрагенты">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Content="Добавить" Command="{Binding Counterparties.AddCommand}" />
                    <Button Margin="0,0,8,0" Content="Редактировать" Command="{Binding Counterparties.EditCommand}" />
                    <Button Margin="0,0,8,0" Content="Просмотр" Command="{Binding Counterparties.ViewCommand}" />
                    <Button Margin="0,0,8,0" Content="Удалить" Command="{Binding Counterparties.DeleteCommand}" />
                    <Button Content="Обновить" Command="{Binding Counterparties.RefreshCommand}" />
                </StackPanel>
                <DataGrid x:Name="CounterpartiesGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Counterparties.Items}"
                          SelectedItem="{Binding Counterparties.SelectedItem}"
                          MouseDoubleClick="CounterpartiesGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="150" />
                        <DataGridTextColumn Header="Куратор" Binding="{Binding Curator.FullName}" Width="200" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>

        <TabItem Header="Заказы">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Content="Добавить" Command="{Binding Orders.AddCommand}" />
                    <Button Margin="0,0,8,0" Content="Редактировать" Command="{Binding Orders.EditCommand}" />
                    <Button Margin="0,0,8,0" Content="Просмотр" Command="{Binding Orders.ViewCommand}" />
                    <Button Margin="0,0,8,0" Content="Удалить" Command="{Binding Orders.DeleteCommand}" />
                    <Button Content="Обновить" Command="{Binding Orders.RefreshCommand}" />
                </StackPanel>
                <DataGrid x:Name="OrdersGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Orders.Items}"
                          SelectedItem="{Binding Orders.SelectedItem}"
                          MouseDoubleClick="OrdersGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=d}" Width="120" />
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="*" />
                        <DataGridTextColumn Header="Контрагент" Binding="{Binding Counterparty.Name}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
